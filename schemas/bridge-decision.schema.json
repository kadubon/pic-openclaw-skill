{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BridgeDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision_id", "input_ref", "phase", "mode", "decision", "allowed_to_execute", "policy_allows_next_step", "requires_human_review", "requires_user_authorization", "pic_used", "missing_obligations", "residual_summary", "pic_diagnostics", "safe_next_steps", "reasons", "safety_boundary"],
  "properties": {
    "schema_version": {"type": "string", "default": "0.1.0"},
    "decision_id": {"type": "string"},
    "input_ref": {"type": "string"},
    "phase": {"type": "string"},
    "mode": {"enum": ["observe", "advisory", "enforce"]},
    "decision": {"enum": ["allow", "warn", "defer", "block"]},
    "allowed_to_execute": {"type": "boolean"},
    "policy_allows_next_step": {"type": "boolean"},
    "requires_human_review": {"type": "boolean"},
    "requires_user_authorization": {"type": "boolean"},
    "pic_used": {"type": "boolean"},
    "pic_accepted": {"type": ["boolean", "null"]},
    "pic_workflow_usable": {"type": ["boolean", "null"]},
    "pic_operationally_usable": {"type": ["boolean", "null"]},
    "pic_settled": {"type": ["boolean", "null"]},
    "missing_obligations": {"type": "array", "items": {"type": "string"}},
    "residual_summary": {"type": "object", "additionalProperties": {"type": "number"}},
    "pic_diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workflow_usable", "unresolved_obligations", "next_safe_actions", "schema_refs", "safety_invariants", "checked_outputs", "phase_diagnostics", "agent_tasks", "route_execution_requests", "residual_ledger", "provenance_refs"],
      "properties": {
        "workflow_usable": {"type": ["boolean", "null"]},
        "unresolved_obligations": {"type": "array", "items": {"type": "string"}},
        "next_safe_actions": {"type": "array", "items": {"type": "string"}},
        "schema_refs": {"type": "array", "items": {"type": "string"}},
        "safety_invariants": {"type": "array", "items": {"type": "string"}},
        "checked_outputs": {"type": "array", "items": {"type": "string"}},
        "phase_diagnostics": {"type": "array", "items": {"type": "string"}},
        "agent_tasks": {"type": "array", "items": {"type": "string"}},
        "route_execution_requests": {"type": "array", "items": {"type": "string"}},
        "residual_ledger": {"type": "array", "items": {"type": "string"}},
        "provenance_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "safe_next_steps": {"type": "array", "items": {"type": "string"}},
    "reasons": {"type": "array", "items": {"type": "string"}},
    "safety_boundary": {"type": "array", "items": {"type": "string"}}
  }
}
